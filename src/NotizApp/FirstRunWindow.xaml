<Window x:Class="NotizApp.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotizApp einrichten" SizeToContent="Height" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Willkommen! 👋" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                   Text="Wo sollen deine Notizen gespeichert werden? Alle Notizen liegen dort als normale Markdown-Dateien. Ein Ordner in OneDrive oder auf dem Netzlaufwerk wird automatisch mitsynchronisiert."/>
        <DockPanel Margin="0,16,0,0">
            <Button DockPanel.Dock="Right" Content="Durchsuchen…" Padding="10,4"
                    Margin="8,0,0,0" Click="Durchsuchen_Click"/>
            <TextBox x:Name="OrdnerBox" Padding="4" VerticalContentAlignment="Center"/>
        </DockPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Los geht's" MinWidth="110" Padding="0,6"
                    IsDefault="True" FontWeight="SemiBold" Click="Los_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
