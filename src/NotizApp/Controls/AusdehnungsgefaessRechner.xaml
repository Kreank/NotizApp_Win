<UserControl x:Class="NotizApp.Controls.AusdehnungsgefaessRechner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FeldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextLeiseBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Eingabe" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="{DynamicResource AppFlaecheTiefBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppRandBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
        <StackPanel Margin="24" MaxWidth="540" HorizontalAlignment="Left">

            <TextBlock Text="🎈 Ausdehnungsgefäß (MAG)" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}"/>
            <TextBlock Text="Nennvolumen überschlägig — geschlossene Heizungsanlage"
                       FontSize="13" Margin="0,2,0,20"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>

            <Border Background="{DynamicResource AppFlaecheBrush}"
                    BorderBrush="{DynamicResource AppRandBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="18">
                <StackPanel>
                    <TextBlock Text="Anlagenwasserinhalt" Style="{StaticResource FeldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock DockPanel.Dock="Right" Text="Liter" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontSize="15"
                                   Foreground="{DynamicResource AppTextLeiseBrush}"/>
                        <TextBox x:Name="InhaltBox" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                    </DockPanel>

                    <TextBlock Text="Max. Vorlauftemperatur" Style="{StaticResource FeldLabel}"/>
                    <ComboBox x:Name="TempBox" Margin="0,0,0,14" Padding="8,6" FontSize="14"
                              SelectionChanged="Auswahl_Changed"/>

                    <TextBlock Text="Statische Höhe der Anlage" Style="{StaticResource FeldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock DockPanel.Dock="Right" Text="m" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontSize="15"
                                   Foreground="{DynamicResource AppTextLeiseBrush}"/>
                        <TextBox x:Name="HoeheBox" Text="5" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                    </DockPanel>

                    <TextBlock Text="Ansprechdruck Sicherheitsventil" Style="{StaticResource FeldLabel}"/>
                    <ComboBox x:Name="SvBox" Padding="8,6" FontSize="14"
                              SelectionChanged="Auswahl_Changed"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppAkzentLeiseBrush}"
                    CornerRadius="10" Padding="18" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Empfohlenes Nenngefäß" Style="{StaticResource FeldLabel}"/>
                    <TextBlock x:Name="ErgebnisGroesse" Text="—" FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"/>
                    <TextBlock x:Name="ErgebnisDetail" Text="" FontSize="12" Margin="0,8,0,0"
                               TextWrapping="Wrap" LineHeight="19"
                               Foreground="{DynamicResource AppTextLeiseBrush}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button x:Name="EinfuegenButton" Content="➕ In Notiz einfügen"
                        Padding="12,7" Margin="0,0,10,0" Click="Einfuegen_Click"/>
                <Button x:Name="KopierenButton" Content="📋 Kopieren"
                        Padding="12,7" Click="Kopieren_Click"/>
            </StackPanel>
            <TextBlock x:Name="HinweisText" Text="" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
