<UserControl x:Class="NotizApp.Controls.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NotizApp.Controls">
    <UserControl.Resources>
        <!-- Rahmenloser, dezenter Button (Kalender-Navigation, Feed aktualisieren) -->
        <Style x:Key="LeiserButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Kopfzeile der Wochentage im Kalender -->
        <Style x:Key="WochentagText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextLeiseBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- ===== Frei platzierbare Dashboard-Karte =====
             Äußerer Rahmen + ContentPresenter (14,26,14,14: oben Platz für die
             Ziehleiste). PART_Move = obere Ziehleiste (⠿), PART_Resize = Griff
             unten rechts. Griffe werden erst beim Überfahren der Karte sichtbar;
             der Rand wechselt dann in die Akzentfarbe. -->
        <Style TargetType="local:DashCard">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:DashCard">
                        <Border x:Name="Rahmen" CornerRadius="14" ClipToBounds="True"
                                Background="{DynamicResource AppFlaecheBrush}"
                                BorderBrush="{DynamicResource AppRandBrush}"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter Margin="14,26,14,14"/>

                                <!-- Obere Ziehleiste: verschiebt die Karte -->
                                <Thumb x:Name="PART_Move" VerticalAlignment="Top"
                                       HorizontalAlignment="Stretch" Height="22"
                                       Cursor="SizeAll">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent">
                                                <TextBlock x:Name="Punkte" Text="⠿" FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Opacity="0.25"
                                                           Foreground="{DynamicResource AppTextLeiseBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Punkte" Property="Opacity" Value="1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>

                                <!-- Griff unten rechts: verändert die Größe -->
                                <Thumb x:Name="PART_Resize" Width="16" Height="16"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE" Opacity="0">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent">
                                                <!-- dezentes Eck-Dreieck -->
                                                <Path Data="M 14,3 L 14,14 L 3,14 Z"
                                                      Fill="{DynamicResource AppTextLeiseBrush}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rahmen" Property="BorderBrush"
                                        Value="{DynamicResource AppAkzentBrush}"/>
                                <Setter TargetName="PART_Resize" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Kopfzeile: Begrüßung + Datum, rechts Feed-Status/-Aktualisierung ===== -->
        <DockPanel Grid.Row="0" Margin="0,0,24,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        VerticalAlignment="Top">
                <TextBlock x:Name="StatusText" FontSize="11" Margin="0,0,8,0"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           MaxWidth="320"
                           Foreground="{DynamicResource AppTextLeiseBrush}"/>
                <Button x:Name="FeedButton" Content="⟳ Feed aktualisieren" FontSize="12"
                        Style="{StaticResource LeiserButton}"
                        ToolTip="Neuigkeiten neu recherchieren (Claude — dauert einige Minuten)"
                        Click="FeedAktualisieren_Click"/>
            </StackPanel>
            <StackPanel>
                <TextBlock x:Name="BegruessungText" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock x:Name="DatumText" FontSize="13" Margin="0,4,0,0"
                           Foreground="{DynamicResource AppTextLeiseBrush}"/>
            </StackPanel>
        </DockPanel>

        <!-- ===== Freie Fläche: alle Karten liegen frei auf dem Board ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto" Padding="0,0,24,24">
            <Canvas x:Name="Board">

                <!-- Kalender-Karte: Inhalt skaliert mit der Kartengröße (Viewbox) -->
                <local:DashCard x:Name="KalenderKarte" CardId="kalender"
                                Canvas.Left="0" Canvas.Top="0" Width="300" Height="360"
                                MinWidth="240" MinHeight="260">
                    <Viewbox Stretch="Uniform" StretchDirection="Both">
                        <StackPanel Width="272">
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Left" Content="‹" FontSize="14"
                                        Style="{StaticResource LeiserButton}"
                                        ToolTip="Voriger Monat" Click="MonatZurueck_Click"/>
                                <Button DockPanel.Dock="Right" Content="›" FontSize="14"
                                        Style="{StaticResource LeiserButton}"
                                        ToolTip="Nächster Monat" Click="MonatVor_Click"/>
                                <TextBlock x:Name="MonatText" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <UniformGrid Columns="7" Margin="0,0,0,4">
                                <TextBlock Text="Mo" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="Di" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="Mi" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="Do" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="Fr" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="Sa" Style="{StaticResource WochentagText}"/>
                                <TextBlock Text="So" Style="{StaticResource WochentagText}"/>
                            </UniformGrid>
                            <!-- 6 Wochenzeilen à 7 Tage, gefüllt im Code-Behind -->
                            <UniformGrid x:Name="KalenderTage" Columns="7" Rows="6"/>
                        </StackPanel>
                    </Viewbox>
                </local:DashCard>

                <!-- Termine-Karte: eigene, getrennte Karte -->
                <local:DashCard x:Name="TermineKarte" CardId="termine"
                                Canvas.Left="0" Canvas.Top="376" Width="300" Height="300"
                                MinWidth="220" MinHeight="160">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="2,0,0,8">
                            <Button DockPanel.Dock="Right" Content="＋ Termin" FontSize="12"
                                    Style="{StaticResource LeiserButton}"
                                    ToolTip="Termin anlegen — am ausgewählten Kalendertag, sonst heute (auch per Doppelklick auf einen Tag)"
                                    Click="TerminAnlegen_Click"/>
                            <TextBlock Text="Termine" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock x:Name="TermineLeer" DockPanel.Dock="Top" FontSize="12"
                                   Margin="2,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTextLeiseBrush}"
                                   Text="Keine anstehenden Termine. Aufgaben mit Datum (@2026-07-09) erscheinen hier."/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TerminListe">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="8,6" Margin="0,0,0,4"
                                                Cursor="Hand" MouseLeftButtonUp="Termin_Click"
                                                ToolTip="Klick öffnet die Quell-Notiz">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{DynamicResource AppAkzentLeiseBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Width="68"
                                                           Text="{Binding DatumKompakt}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Margin="0,1,6,0"
                                                           Foreground="{DynamicResource AppKupferBrush}"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Text}" FontSize="13"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding NotizTitel}" FontSize="11"
                                                               Margin="0,1,0,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource AppTextLeiseBrush}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </local:DashCard>

                <!-- News-Karten werden im Code-Behind (ZeigeFeedKarten) erzeugt -->
            </Canvas>
        </ScrollViewer>
    </Grid>
</UserControl>
