<UserControl x:Class="NotizApp.Controls.VolumenstromRechner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FeldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextLeiseBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Eingabe" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="{DynamicResource AppFlaecheTiefBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppRandBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
        <StackPanel Margin="24" MaxWidth="540" HorizontalAlignment="Left">

            <TextBlock Text="💧 Volumenstrom" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}"/>
            <TextBlock Text="Durchfluss aus Heizleistung und Spreizung (Wasser)"
                       FontSize="13" Margin="0,2,0,20"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>

            <Border Background="{DynamicResource AppFlaecheBrush}"
                    BorderBrush="{DynamicResource AppRandBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="18">
                <StackPanel>
                    <TextBlock Text="Heizleistung" Style="{StaticResource FeldLabel}"/>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock DockPanel.Dock="Right" Text="kW" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontSize="15"
                                   Foreground="{DynamicResource AppTextLeiseBrush}"/>
                        <TextBox x:Name="LeistungBox" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                    </DockPanel>

                    <TextBlock Text="Spreizung (Vorlauf − Rücklauf)" Style="{StaticResource FeldLabel}"/>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Right" Text="K" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontSize="15"
                                   Foreground="{DynamicResource AppTextLeiseBrush}"/>
                        <TextBox x:Name="SpreizungBox" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="20 K (Heizkörper)" Tag="20" Click="Preset_Click"
                                Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
                        <Button Content="10 K" Tag="10" Click="Preset_Click"
                                Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
                        <Button Content="7 K (FBH)" Tag="7" Click="Preset_Click"
                                Padding="8,3" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppAkzentLeiseBrush}"
                    CornerRadius="10" Padding="18" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Volumenstrom" Style="{StaticResource FeldLabel}"/>
                    <TextBlock x:Name="ErgebnisLh" Text="—" FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"/>
                    <TextBlock x:Name="ErgebnisFormel" Text="" FontSize="13" Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppTextLeiseBrush}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button x:Name="EinfuegenButton" Content="➕ In Notiz einfügen"
                        Padding="12,7" Margin="0,0,10,0" Click="Einfuegen_Click"/>
                <Button x:Name="KopierenButton" Content="📋 Kopieren"
                        Padding="12,7" Click="Kopieren_Click"/>
            </StackPanel>
            <TextBlock x:Name="HinweisText" Text="" FontSize="12" Margin="0,10,0,0"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
