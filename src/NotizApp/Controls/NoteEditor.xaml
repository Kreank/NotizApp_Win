<UserControl x:Class="NotizApp.Controls.NoteEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NotizApp.Controls"
             x:Name="Wurzel">
    <UserControl.Resources>
        <Style x:Key="RahmenlosTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <!-- Design-Farben statt WPF-Standard-Schwarz (im Dark Mode sonst unlesbar) -->
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextBrush}"/>
        </Style>
        <!-- Flache, moderne Werkzeug-Schaltflächen: transparent, abgerundet,
             dezenter Hover; aktives Werkzeug (Toggle) in Akzentfarbe.
             Ersetzt die graue WPF-Standard-Optik. -->
        <Style x:Key="WerkzeugToggle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="B" CornerRadius="6" SnapsToDevicePixels="True"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource AppFlaecheBrush}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource AppRandBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource AppAkzentLeiseBrush}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource AppAkzentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WerkzeugButton" TargetType="Button">
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="6" SnapsToDevicePixels="True"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource AppFlaecheBrush}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource AppRandBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource AppAkzentLeiseBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Textfeld eines Text-Elements: Farbe aus dem VM, sonst Design-Farbe -->
        <Style x:Key="ElementTextBox" TargetType="TextBox" BasedOn="{StaticResource RahmenlosTextBox}">
            <Setter Property="Foreground" Value="{Binding FarbBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="FontFamily" Value="{Binding SchriftFamily}"/>
            <!-- merkt sich das gerade bearbeitete Textfeld für Farb-/Schriftwahl -->
            <EventSetter Event="GotKeyboardFocus" Handler="TextFeld_Fokus"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FarbBrush}" Value="{x:Null}">
                    <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Verschiebe-Griff (⠿) über jedem Element -->
        <ControlTemplate x:Key="GriffTemplate" TargetType="Thumb">
            <Border Background="{DynamicResource AppFlaecheBrush}"
                    BorderBrush="{DynamicResource AppRandBrush}" BorderThickness="1"
                    CornerRadius="3" Padding="6,0">
                <TextBlock Text="⠿" FontSize="10" Opacity="0.7"
                           Foreground="{DynamicResource AppTextBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <!-- Unsichtbarer Größen-Griff (Kante/Ecke) -->
        <ControlTemplate x:Key="LeiseGriffTemplate" TargetType="Thumb">
            <Border Background="Transparent">
                <Border Background="{DynamicResource AppTextLeiseBrush}"
                        CornerRadius="2" Margin="2" Opacity="0.5"/>
            </Border>
        </ControlTemplate>

        <Style x:Key="LoeschKnopf" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="ToolTip" Value="Element löschen"/>
            <!-- Design-Textfarbe statt WPF-Schwarz (Dark Mode) — betrifft auch
                 die Tabellen-Griffleiste (＋Zeile/－Spalte …), die hierauf basiert -->
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        </Style>

        <!-- ===== Textfeld-Element ===== -->
        <DataTemplate DataType="{x:Type local:TextElementVm}">
            <Grid Background="Transparent">
                <Border x:Name="Rahmen" BorderThickness="1" CornerRadius="3"
                        BorderBrush="Transparent" Padding="2">
                    <TextBox Width="{Binding Breite}" MinHeight="26"
                             Style="{StaticResource ElementTextBox}"
                             Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap" FontSize="{Binding SchriftGroesse}"
                             SpellCheck.IsEnabled="False"
                             SizeChanged="TextElement_SizeChanged"/>
                </Border>
                <StackPanel x:Name="Griff" Orientation="Horizontal" Opacity="0"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="0,-18,0,0">
                    <Thumb Width="36" Height="16" Cursor="SizeAll"
                           Template="{StaticResource GriffTemplate}"
                           ToolTip="Verschieben"
                           DragDelta="ElementVerschieben_DragDelta"/>
                    <Button Content="🗑" Style="{StaticResource LoeschKnopf}"
                            Click="ElementLoeschen_Click"/>
                </StackPanel>
                <Thumb x:Name="BreiteGriff" Width="7" Opacity="0" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Stretch"
                       Margin="0,4" ToolTip="Breite ziehen"
                       Template="{StaticResource LeiseGriffTemplate}"
                       DragDelta="TextBreite_DragDelta"/>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Griff" Property="Opacity" Value="1"/>
                    <Setter TargetName="BreiteGriff" Property="Opacity" Value="0.7"/>
                    <Setter TargetName="Rahmen" Property="BorderBrush"
                            Value="{DynamicResource AppRandBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Rahmen" Property="BorderBrush"
                            Value="{DynamicResource AppAkzentBrush}"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ===== Tabellen-Element ===== -->
        <DataTemplate DataType="{x:Type local:TabelleElementVm}">
            <Grid Background="Transparent" Width="{Binding Breite}">
                <Border x:Name="Rahmen" BorderThickness="1" CornerRadius="4"
                        BorderBrush="{DynamicResource AppRandBrush}"
                        Background="{DynamicResource AppFlaecheBrush}"
                        SizeChanged="Tabelle_SizeChanged">
                    <ItemsControl ItemsSource="{Binding Zeilen}" AlternationCount="9999">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ZeilenRahmen" MinHeight="{Binding MinHoehe}">
                                    <Grid>
                                        <ItemsControl ItemsSource="{Binding Zellen}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{Binding Breite}"
                                                            BorderThickness="0,0,1,1"
                                                            BorderBrush="{DynamicResource AppRandBrush}">
                                                        <Grid>
                                                            <TextBox x:Name="ZellBox"
                                                                     Style="{StaticResource RahmenlosTextBox}"
                                                                     Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     AcceptsReturn="True" AcceptsTab="False"
                                                                     TextWrapping="Wrap" FontSize="13"
                                                                     Padding="6,4" MinHeight="27"
                                                                     SpellCheck.IsEnabled="False"
                                                                     PreviewKeyDown="TabellenZelle_KeyDown">
                                                                <TextBox.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="🖼 Bild in Zelle…"
                                                                                  Click="TabellenZellBild_Click"/>
                                                                        <MenuItem Header="Bild entfernen"
                                                                                  Click="TabellenZellBildWeg_Click"/>
                                                                    </ContextMenu>
                                                                </TextBox.ContextMenu>
                                                            </TextBox>
                                                            <Image x:Name="ZellBild" Visibility="Collapsed"
                                                                   Source="{Binding BildQuelle}" Stretch="Uniform"
                                                                   Margin="4" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   IsHitTestVisible="False"/>
                                                            <!-- Spaltenbreite ziehen (rechte Zellkante) -->
                                                            <Thumb Width="6" HorizontalAlignment="Right"
                                                                   Cursor="SizeWE" ToolTip="Spaltenbreite ziehen"
                                                                   DragDelta="TabelleSpalteBreite_DragDelta">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Border Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding HatBild}" Value="True">
                                                            <Setter TargetName="ZellBild" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="ZellBox" Property="Foreground" Value="Transparent"/>
                                                            <Setter TargetName="ZellBox" Property="MinHeight" Value="60"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Zeilenhöhe ziehen (untere Zeilenkante) -->
                                        <Thumb Height="5" VerticalAlignment="Bottom"
                                               HorizontalAlignment="Stretch"
                                               Cursor="SizeNS" ToolTip="Zeilenhöhe ziehen"
                                               DragDelta="TabelleZeileHoehe_DragDelta">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Erste Zeile = Kopfzeile: halbfett auf tieferem Grund -->
                                    <DataTrigger Binding="{Binding Path=(ItemsControl.AlternationIndex),
                                            RelativeSource={RelativeSource TemplatedParent}}" Value="0">
                                        <Setter TargetName="ZeilenRahmen" Property="Background"
                                                Value="{DynamicResource AppFlaecheTiefBrush}"/>
                                        <Setter TargetName="ZeilenRahmen" Property="TextElement.FontWeight"
                                                Value="SemiBold"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Griffleiste (beim Drüberfahren): verschieben, Zeilen/Spalten, löschen -->
                <StackPanel x:Name="Griff" Orientation="Horizontal" Opacity="0"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="0,-19,0,0">
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource LoeschKnopf}">
                            <Setter Property="ToolTip" Value="{x:Null}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </StackPanel.Resources>
                    <Thumb Width="36" Height="16" Cursor="SizeAll"
                           Template="{StaticResource GriffTemplate}"
                           ToolTip="Verschieben"
                           DragDelta="ElementVerschieben_DragDelta"/>
                    <Button Content="＋Zeile" ToolTip="Zeile unten anfügen" Click="TabelleZeile_Click"/>
                    <Button Content="＋Spalte" ToolTip="Spalte rechts anfügen" Click="TabelleSpalte_Click"/>
                    <Button Content="−Zeile" ToolTip="Letzte Zeile entfernen" Click="TabelleZeileWeg_Click"/>
                    <Button Content="−Spalte" ToolTip="Letzte Spalte entfernen" Click="TabelleSpalteWeg_Click"/>
                    <Button Content="🗑" ToolTip="Tabelle löschen" Click="ElementLoeschen_Click"/>
                </StackPanel>
                <Thumb x:Name="BreiteGriff" Width="7" Opacity="0" Cursor="SizeWE"
                       HorizontalAlignment="Right" VerticalAlignment="Stretch"
                       Margin="0,4" ToolTip="Breite ziehen"
                       Template="{StaticResource LeiseGriffTemplate}"
                       DragDelta="TabelleBreite_DragDelta"/>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Griff" Property="Opacity" Value="1"/>
                    <Setter TargetName="BreiteGriff" Property="Opacity" Value="0.7"/>
                    <Setter TargetName="Rahmen" Property="BorderBrush"
                            Value="{DynamicResource AppAkzentBrush}"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ===== Bild-Element ===== -->
        <DataTemplate DataType="{x:Type local:BildElementVm}">
            <Grid Width="{Binding Breite}" Height="{Binding Hoehe}" Background="Transparent">
                <Border Background="{Binding Hintergrund}" CornerRadius="2"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppRandBrush}"/>
                <!-- Ganzflächiger Griff: im Auswahl-Modus direkt anfassbar -->
                <Thumb Cursor="SizeAll" DragDelta="ElementVerschieben_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Button x:Name="Loeschen" Content="🗑" Opacity="0"
                        Style="{StaticResource LoeschKnopf}"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                        Click="ElementLoeschen_Click"/>
                <Thumb x:Name="EckGriff" Width="14" Height="14" Opacity="0"
                       Cursor="SizeNWSE" ToolTip="Größe ziehen (proportional)"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Template="{StaticResource LeiseGriffTemplate}"
                       DragDelta="BildGroesse_DragDelta"/>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Loeschen" Property="Opacity" Value="1"/>
                    <Setter TargetName="EckGriff" Property="Opacity" Value="0.8"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ===== Datei-Element (Karte, PDFs mit Vorschau) ===== -->
        <DataTemplate DataType="{x:Type local:DateiElementVm}">
            <Grid Width="{Binding Breite}" Height="{Binding Hoehe}" Background="Transparent"
                  PreviewMouseLeftButtonDown="DateiElement_MouseDown">
                <Border Background="{DynamicResource AppFlaecheBrush}"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource AppRandBrush}"
                        Padding="8" ToolTip="Doppelklick: Datei öffnen">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Name}"
                                   FontSize="11" Margin="0,4,0,0" Opacity="0.8"
                                   TextTrimming="CharacterEllipsis"/>
                        <Grid>
                            <StackPanel x:Name="IconKarte" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Icon}" FontSize="26"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="VorschauKarte" Background="White"
                                    Visibility="Collapsed" CornerRadius="2">
                                <Image Source="{Binding Vorschau}" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
                <Thumb Cursor="SizeAll" DragDelta="ElementVerschieben_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Button x:Name="Loeschen" Content="🗑" Opacity="0"
                        Style="{StaticResource LoeschKnopf}"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                        Click="ElementLoeschen_Click"/>
                <!-- PDF-Seiten blättern (nur bei mehrseitigen PDFs, beim Drüberfahren) -->
                <Border x:Name="SeitenNav" CornerRadius="11" Opacity="0" Padding="4,1"
                        Background="#B0202020" IsHitTestVisible="False"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,26">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="7,0"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </StackPanel.Resources>
                        <Button Content="‹" ToolTip="Vorherige Seite" Click="PdfSeiteZurueck_Click"/>
                        <TextBlock Text="{Binding SeitenInfo}" Foreground="White" FontSize="11"
                                   VerticalAlignment="Center" Margin="2,0"/>
                        <Button Content="›" ToolTip="Nächste Seite" Click="PdfSeiteVor_Click"/>
                    </StackPanel>
                </Border>
                <Thumb x:Name="EckGriff" Width="14" Height="14" Opacity="0"
                       Cursor="SizeNWSE" ToolTip="Größe ziehen"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Template="{StaticResource LeiseGriffTemplate}"
                       DragDelta="DateiGroesse_DragDelta"/>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Loeschen" Property="Opacity" Value="1"/>
                    <Setter TargetName="EckGriff" Property="Opacity" Value="0.8"/>
                </Trigger>
                <DataTrigger Binding="{Binding HatVorschau}" Value="True">
                    <Setter TargetName="VorschauKarte" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="IconKarte" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding MehrereSeiten}" Value="True"/>
                        <Condition Binding="{Binding IsMouseOver,
                            RelativeSource={RelativeSource AncestorType=Grid}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="SeitenNav" Property="Opacity" Value="1"/>
                    <Setter TargetName="SeitenNav" Property="IsHitTestVisible" Value="True"/>
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <!-- ===== Link-Element (Web-Clip-Karte) ===== -->
        <DataTemplate DataType="{x:Type local:LinkElementVm}">
            <Grid Width="{Binding Breite}" Height="{Binding Hoehe}" Background="Transparent"
                  PreviewMouseLeftButtonDown="LinkElement_MouseDown"
                  MouseWheel="LinkElement_MouseWheel">
                <Border Background="{DynamicResource AppFlaecheBrush}"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="{DynamicResource AppRandBrush}"
                        ToolTip="Doppelklick: Link im Browser öffnen">
                    <Grid>
                        <!-- Gerenderte Seiten-Vorschau (falls vorhanden) über der Titelzeile.
                             Füllen-Modus: Bild in Rahmenbreite, oben ausgerichtet, per
                             Mausrad im Rahmen scrollbar (TranslateTransform im Code). -->
                        <Border x:Name="VorschauRahmen" Visibility="Collapsed"
                                Margin="1,1,1,52" ClipToBounds="True"
                                CornerRadius="5,5,0,0" Background="White"
                                SizeChanged="LinkVorschau_SizeChanged">
                            <Image x:Name="VorschauBild" Source="{Binding Vorschau}"
                                   Stretch="Uniform"
                                   Width="{Binding ActualWidth,
                                       RelativeSource={RelativeSource AncestorType=Border}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   SizeChanged="LinkVorschau_SizeChanged">
                                <Image.RenderTransform>
                                    <TranslateTransform/>
                                </Image.RenderTransform>
                            </Image>
                        </Border>
                        <DockPanel x:Name="TitelZeile" Margin="8,0" VerticalAlignment="Center">
                            <TextBlock DockPanel.Dock="Left" Text="🔗" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TitelText" Text="{Binding Titel}" FontWeight="SemiBold"
                                           TextWrapping="Wrap" MaxHeight="38"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppTextBrush}"/>
                                <TextBlock Text="{Binding Domain}" FontSize="11" Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppTextLeiseBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
                <!-- Ganzflächiger Griff: im Auswahl-Modus direkt anfassbar -->
                <Thumb Cursor="SizeAll" DragDelta="ElementVerschieben_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Button x:Name="Loeschen" Content="🗑" Opacity="0"
                        Style="{StaticResource LoeschKnopf}"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                        Click="ElementLoeschen_Click"/>
                <Button x:Name="NeuLadenKnopf" Content="⟳" Opacity="0"
                        Style="{StaticResource LoeschKnopf}"
                        ToolTip="Titel und Vorschau neu laden"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="4,4,28,4" Click="LinkNeuLaden_Click"/>
                <Button x:Name="ModusKnopf" Content="⤢" Opacity="0"
                        Style="{StaticResource LoeschKnopf}" Visibility="Collapsed"
                        ToolTip="Ganze Seite einpassen / Ausschnitt füllen"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="4,4,52,4" Click="LinkModus_Click"/>
                <Button x:Name="PdfKnopf" Content="⬇ PDF" Opacity="0" FontSize="11"
                        Style="{StaticResource LoeschKnopf}"
                        ToolTip="Seite als PDF neben der Notiz sichern"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="4,4,20,4" Click="LinkPdf_Click"/>
                <Thumb x:Name="EckGriff" Width="14" Height="14" Opacity="0"
                       Cursor="SizeNWSE" ToolTip="Größe ziehen"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Template="{StaticResource LeiseGriffTemplate}"
                       DragDelta="LinkGroesse_DragDelta"/>
            </Grid>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Loeschen" Property="Opacity" Value="1"/>
                    <Setter TargetName="NeuLadenKnopf" Property="Opacity" Value="1"/>
                    <Setter TargetName="ModusKnopf" Property="Opacity" Value="1"/>
                    <Setter TargetName="PdfKnopf" Property="Opacity" Value="1"/>
                    <Setter TargetName="EckGriff" Property="Opacity" Value="0.8"/>
                </Trigger>
                <!-- Mit Vorschau: Bild füllt die Karte, Titelzeile kompakt darunter -->
                <DataTrigger Binding="{Binding HatVorschau}" Value="True">
                    <Setter TargetName="VorschauRahmen" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ModusKnopf" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="TitelZeile" Property="VerticalAlignment" Value="Bottom"/>
                    <Setter TargetName="TitelZeile" Property="Height" Value="52"/>
                    <Setter TargetName="TitelText" Property="TextWrapping" Value="NoWrap"/>
                </DataTrigger>
                <!-- Einpassen-Modus: ganze Seite sichtbar (Letterbox), Scrollen inaktiv -->
                <DataTrigger Binding="{Binding VorschauEingepasst}" Value="True">
                    <Setter TargetName="VorschauBild" Property="Width" Value="Auto"/>
                    <Setter TargetName="VorschauBild" Property="HorizontalAlignment" Value="Center"/>
                    <Setter TargetName="VorschauBild" Property="VerticalAlignment" Value="Center"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel (mit Platzhalter, solange leer) -->
        <Grid Grid.Row="0" Margin="16,12,16,0">
            <TextBlock Text="Titel eingeben…" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextLeiseBrush}" Opacity="0.55"
                       IsHitTestVisible="False" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Text, ElementName=TitelBox}" Value=""/>
                                    <Condition Binding="{Binding IsEnabled, ElementName=Wurzel}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="TitelBox"
                     Style="{StaticResource RahmenlosTextBox}"
                     FontSize="24" FontWeight="SemiBold"
                     ToolTip="Titel der Notiz"
                     TextChanged="Meta_TextChanged"/>
        </Grid>

        <!-- Tags -->
        <DockPanel Grid.Row="1" Margin="16,4,16,0">
            <TextBlock Text="🏷" DockPanel.Dock="Left" VerticalAlignment="Center"
                       Margin="0,0,6,0" Opacity="0.6"/>
            <TextBox x:Name="TagsBox" Style="{StaticResource RahmenlosTextBox}"
                     FontSize="13" Foreground="{DynamicResource AppTextLeiseBrush}"
                     TextChanged="Meta_TextChanged"
                     ToolTip="Tags durch Komma getrennt, z.B.: notfall, heizung"/>
        </DockPanel>

        <!-- Kopf: Kundendaten -->
        <Expander x:Name="KopfExpander" Grid.Row="2" Margin="16,6,16,0"
                  Header="Kopf: Kundendaten (bleibt lokal, geht nie an die KI)">
            <Grid Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Beschriftung"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,4,8,4"/>
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Margin" Value="0,4,12,4"/>
                    </Style>
                </Grid.Resources>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"/>
                <TextBox x:Name="KundeNameBox" Grid.Row="0" Grid.Column="1"
                         TextChanged="Meta_TextChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Telefon"/>
                <TextBox x:Name="KundeTelefonBox" Grid.Row="0" Grid.Column="3"
                         TextChanged="Meta_TextChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Adresse"/>
                <TextBox x:Name="KundeAdresseBox" Grid.Row="1" Grid.Column="1"
                         Grid.ColumnSpan="3" TextChanged="Meta_TextChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Dringlichkeit"/>
                <ComboBox x:Name="DringlichkeitBox" Grid.Row="2" Grid.Column="1"
                          Margin="0,4,12,4" SelectionChanged="Meta_SelectionChanged">
                    <ComboBoxItem Content="—" Tag=""/>
                    <ComboBoxItem Content="Notfall" Tag="notfall"/>
                    <ComboBoxItem Content="Termin" Tag="termin"/>
                    <ComboBoxItem Content="Terminierung" Tag="terminierung"/>
                    <ComboBoxItem Content="Info" Tag="info"/>
                </ComboBox>
                <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal">
                    <TextBlock Text="Typ"/>
                    <ComboBox x:Name="TypBox" Margin="0,4,0,4" MinWidth="130"
                              SelectionChanged="Meta_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Expander>

        <!-- Werkzeugleiste -->
        <Border Grid.Row="3" Margin="16,10,16,6" Padding="6,4" CornerRadius="8"
                Background="{DynamicResource AppFlaecheBrush}"
                BorderBrush="{DynamicResource AppRandBrush}" BorderThickness="1">
            <WrapPanel VerticalAlignment="Center">
                <ToggleButton x:Name="FokusToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="⛶" ToolTip="Fokus-Modus: Seitenleisten ein-/ausklappen (F11)"
                              Checked="Fokus_Umschalten" Unchecked="Fokus_Umschalten"/>

                <Separator Margin="6,2" Width="1"/>

                <Button x:Name="UndoButton" Style="{StaticResource WerkzeugButton}"
                        Content="↶" IsEnabled="False" ToolTip="Rückgängig (Strg+Z)"
                        Click="Undo_Click"/>
                <Button x:Name="RedoButton" Style="{StaticResource WerkzeugButton}"
                        Content="↷" IsEnabled="False" ToolTip="Wiederholen (Strg+Y)"
                        Click="Redo_Click"/>

                <Separator Margin="6,2" Width="1"/>

                <ToggleButton x:Name="AuswahlToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="➤" IsChecked="True"
                              ToolTip="Auswählen/Tippen (A): Klick wählt Striche und Objekte, Ziehen auf freier Fläche spannt ein Auswahlrechteck auf. Mausklick auf die freie Fläche = Textfeld zum Lostippen (mit dem Stift: Doppeltipp)."
                              Checked="Werkzeug_Checked"/>
                <ToggleButton x:Name="StiftToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="🖊" Checked="Werkzeug_Checked"
                              ToolTip="Stift (S). Mit Digitizer-Stift gilt: Der Stift zeichnet, die Maus tippt und bearbeitet Text — ohne Werkzeugwechsel."/>
                <ToggleButton x:Name="MarkerToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="🖍" ToolTip="Textmarker (M)" Checked="Werkzeug_Checked"/>
                <ToggleButton x:Name="RadiererToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="⌫" ToolTip="Radierer: ganze Striche (R)" Checked="Werkzeug_Checked"/>
                <ToggleButton x:Name="PunktRadiererToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="◌" ToolTip="Radierer: punktgenau (P) — Größe über den Regler"
                              Checked="Werkzeug_Checked"/>
                <ToggleButton x:Name="LassoToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="⬚" ToolTip="Lasso-Auswahl (L)" Checked="Werkzeug_Checked"/>
                <ToggleButton x:Name="FormToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="▭" Checked="Werkzeug_Checked" Click="FormToggle_Click"
                              ToolTip="Formen (F): Rechteck, Quadrat, Ellipse, Kreis, Dreieck, Linien (auch gestrichelt/gepunktet). Auf der Fläche aufziehen — gezeichnet wird in der Stiftfarbe. Erneuter Klick auf den Button wechselt die Form. Zoom: Strg+Mausrad, Strg+0 = 100 %."/>
                <Button x:Name="UmwandelnButton" Style="{StaticResource WerkzeugButton}"
                        Content="⬚→A" IsEnabled="False"
                        ToolTip="Markierte Handschrift in Tipptext umwandeln (übernimmt die Stiftfarbe)"
                        Click="AuswahlZuText_Click"/>

                <Separator Margin="6,2" Width="1"/>

                <WrapPanel x:Name="FarbLeiste" VerticalAlignment="Center">
                    <WrapPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource WerkzeugButton}">
                            <Setter Property="Padding" Value="4,4"/>
                            <Setter Property="Margin" Value="1,0"/>
                        </Style>
                    </WrapPanel.Resources>
                    <Button ToolTip="Blau" Click="Farbe_Click" Tag="#3B78D8">
                        <Ellipse Width="14" Height="14" Fill="#3B78D8"/>
                    </Button>
                    <Button ToolTip="Automatisch (Schwarz im hellen, Weiß im dunklen Design)"
                            Click="Farbe_Click" Tag="auto">
                        <Ellipse Width="14" Height="14" Stroke="Gray">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="Black" Offset="0.49"/>
                                    <GradientStop Color="White" Offset="0.51"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Button>
                    <Button ToolTip="Rot" Click="Farbe_Click" Tag="#D83B3B">
                        <Ellipse Width="14" Height="14" Fill="#D83B3B"/>
                    </Button>
                    <Button ToolTip="Grün" Click="Farbe_Click" Tag="#3B9E5F">
                        <Ellipse Width="14" Height="14" Fill="#3B9E5F"/>
                    </Button>
                    <Button ToolTip="Orange" Click="Farbe_Click" Tag="#E8871E">
                        <Ellipse Width="14" Height="14" Fill="#E8871E"/>
                    </Button>
                    <Button ToolTip="Gelb" Click="Farbe_Click" Tag="#E3C71B">
                        <Ellipse Width="14" Height="14" Fill="#E3C71B"/>
                    </Button>
                    <Button ToolTip="Violett" Click="Farbe_Click" Tag="#8E5BD8">
                        <Ellipse Width="14" Height="14" Fill="#8E5BD8"/>
                    </Button>
                    <Button ToolTip="Türkis" Click="Farbe_Click" Tag="#2BAAB4">
                        <Ellipse Width="14" Height="14" Fill="#2BAAB4"/>
                    </Button>
                    <Button ToolTip="Pink" Click="Farbe_Click" Tag="#D85BA6">
                        <Ellipse Width="14" Height="14" Fill="#D85BA6"/>
                    </Button>
                    <Button ToolTip="Braun" Click="Farbe_Click" Tag="#8B5A3C">
                        <Ellipse Width="14" Height="14" Fill="#8B5A3C"/>
                    </Button>
                </WrapPanel>

                <ComboBox x:Name="SchriftBox" Width="128" Margin="4,0,2,0" FontSize="12"
                          VerticalAlignment="Center" MaxDropDownHeight="360"
                          Foreground="{DynamicResource AppTextBrush}"
                          ToolTip="Schriftart des aktiven Textfeldes — erst ins Textfeld klicken, dann Schrift wählen"
                          SelectionChanged="Schrift_Changed"/>

                <ComboBox x:Name="SchriftGroesseBox" Width="56" Margin="0,0,4,0" FontSize="12"
                          IsEditable="True" VerticalAlignment="Center" MaxDropDownHeight="360"
                          Foreground="{DynamicResource AppTextBrush}"
                          ToolTip="Schriftgröße des aktiven Textfeldes — erst ins Textfeld klicken, dann Größe wählen oder eintippen"
                          SelectionChanged="SchriftGroesse_Changed"
                          LostFocus="SchriftGroesse_LostFocus"
                          PreviewKeyDown="SchriftGroesse_KeyDown"/>

                <Separator Margin="6,2" Width="1"/>

                <Slider x:Name="DickeSlider" Width="90" Minimum="1" Maximum="14"
                        Value="2.2" VerticalAlignment="Center" Margin="2,0"
                        ToolTip="Stift-/Radierergröße"
                        ValueChanged="DickeSlider_ValueChanged"/>
                <Border Width="22" Height="22" VerticalAlignment="Center" Margin="2,0"
                        ToolTip="Vorschau: aktuelle Farbe und Größe">
                    <Ellipse x:Name="VorschauPunkt" Width="4" Height="4" Fill="#3B78D8"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Separator Margin="6,2" Width="1"/>

                <ToggleButton x:Name="ErkennungToggle" Style="{StaticResource WerkzeugToggle}"
                              Content="✍→A Handschrift → Text"
                              ToolTip="Aktiv: Geschriebenes wird zu Tipptext an der Schreibstelle — in der Stiftfarbe. Inaktiv: Tinte bleibt Tinte (wird für die Suche trotzdem im Hintergrund erkannt)."/>

                <Button Style="{StaticResource WerkzeugButton}" Content="▦"
                        ToolTip="Papier wechseln: Blanko → Liniert → Kariert → Punktraster"
                        Click="Muster_Click"/>

                <Button x:Name="VorlageButton" Style="{StaticResource WerkzeugButton}" Content="📋 Vorlage"
                        ToolTip="Vorlage in die Notiz einfügen (Anruf, Meeting, Begehung, eigene Vorlagen …)"
                        Click="Vorlage_Click"/>

                <Button Style="{StaticResource WerkzeugButton}" Content="⊞ Tabelle"
                        ToolTip="Tabelle einfügen (3 Spalten, Kopfzeile + 2 Zeilen) — Zeilen/Spalten über die Griffleiste der Tabelle"
                        Click="TabelleEinfuegen_Click"/>

                <Button Style="{StaticResource WerkzeugButton}" Content="📎 + Datei"
                        ToolTip="Bild oder Datei als Objekt ablegen (png, jpg, pdf, xlsx, docx, md, txt) — verschiebbar, skalierbar, Draufzeichnen inklusive"
                        Click="DateiEinfuegen_Click"/>

                <Button x:Name="AufnahmeButton" Style="{StaticResource WerkzeugButton}" Content="🎙"
                        ToolTip="Gespräch aufnehmen (Mikrofon + PC-Ton) und lokal in Text umwandeln — Klick startet, erneuter Klick stoppt. Wichtig: Gesprächspartner vorher um Einwilligung bitten (§ 201 StGB)."
                        Click="Aufnahme_Click"/>

                <Button Style="{StaticResource WerkzeugButton}" Content="💬 Chat"
                        ToolTip="KI-Chat ein-/ausblenden: recherchieren, Dateien erstellen, Ergebnisse in die Notiz übernehmen"
                        Click="Chat_Click"/>

                <Button x:Name="KiButton" Style="{StaticResource WerkzeugButton}" Content="✨ KI"
                        ToolTip="KI-Aufbereitung (sendet nur den Notiztext, keine Kundendaten)"
                        Click="Ki_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📋 Zusammenfassen" Tag="Zusammenfassen" Click="KiAktion_Click"/>
                            <MenuItem Header="✏ Text aufbereiten" Tag="Aufbereiten" Click="KiAktion_Click"/>
                            <MenuItem Header="☑ Aufgaben extrahieren" Tag="Aufgaben" Click="KiAktion_Click"/>
                            <Separator/>
                            <MenuItem Header="📄 Dateien erstellen/suchen…" Click="KiDokument_Click"/>
                            <Separator/>
                            <MenuItem x:Name="AnhaengeMenuItem" IsCheckable="True"
                                      Header="🖼 Anhänge mitgeben"
                                      ToolTip="Bilder und PDFs der Notiz gehen mit an die KI: PDF-Text wird lokal ausgelesen und mitgeschickt, Bilder kann Claude direkt ansehen. Achtung: Damit verlassen auch personenbezogene Inhalte der Anhänge den PC."/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Button Style="{StaticResource WerkzeugButton}" Content="💾 Speichern"
                        ToolTip="Speichern (Strg+S)" Click="Speichern_Click"/>
            </WrapPanel>
        </Border>

        <!-- Die Fläche: eine Notiz = ein Freiform-Canvas.
             Tinte liegt über allen Objekten; Textfelder/Bilder/Dateien sind Kinder. -->
        <ScrollViewer x:Name="Scroller" Grid.Row="4" Padding="16,0,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly"
                      SizeChanged="Scroller_SizeChanged">
            <InkCanvas x:Name="Flaeche" Background="Transparent" MinHeight="500"
                       AllowDrop="True" Drop="Flaeche_Drop"
                       PreviewMouseLeftButtonDown="Flaeche_MouseLeftButtonDown"
                       PreviewMouseMove="Flaeche_MouseMove"
                       PreviewMouseLeftButtonUp="Flaeche_MouseUp"
                       SelectionChanged="Flaeche_SelectionChanged"/>
        </ScrollViewer>
    </Grid>
</UserControl>
