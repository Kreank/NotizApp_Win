<UserControl x:Class="NotizApp.Controls.WasserinhaltRechner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FeldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextLeiseBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Eingabe" TargetType="TextBox">
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource AppFlaecheTiefBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppRandBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="Einheit" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextLeiseBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
        <StackPanel Margin="24" MaxWidth="560" HorizontalAlignment="Left">

            <TextBlock Text="🪣 Wasserinhalt / Befüllmenge" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}"/>
            <TextBlock Text="Anlagenwasserinhalt als Summe der Komponenten (VDI 2035)"
                       FontSize="13" Margin="0,2,0,20"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>

            <Border Background="{DynamicResource AppFlaecheBrush}"
                    BorderBrush="{DynamicResource AppRandBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="18">
                <StackPanel>
                    <!-- Rohrleitung (Verteilung) -->
                    <TextBlock Text="Rohrleitung (Verteilung, Vor- + Rücklauf gesamt)"
                               Style="{StaticResource FeldLabel}"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RohrLaenge" Grid.Column="0" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                        <TextBlock Grid.Column="1" Text="m ×" Style="{StaticResource Einheit}" Margin="6,0,8,0"/>
                        <ComboBox x:Name="RohrTyp" Grid.Column="2" Padding="7,5" FontSize="13"
                                  SelectionChanged="RohrTyp_Changed"/>
                        <TextBlock Grid.Column="3" Text="l/m" Style="{StaticResource Einheit}"/>
                    </Grid>

                    <!-- Fußbodenheizung -->
                    <TextBlock Text="Fußbodenheizung (Rohrlänge gesamt)"
                               Style="{StaticResource FeldLabel}"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FbhLaenge" Grid.Column="0" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                        <TextBlock Grid.Column="1" Text="m ×" Style="{StaticResource Einheit}" Margin="6,0,8,0"/>
                        <ComboBox x:Name="FbhTyp" Grid.Column="2" Padding="7,5" FontSize="13"
                                  SelectionChanged="FbhTyp_Changed"/>
                        <TextBlock Grid.Column="3" Text="l/m" Style="{StaticResource Einheit}"/>
                    </Grid>

                    <!-- Heizkörper -->
                    <TextBlock Text="Heizkörper (Anzahl × Inhalt je Stück)"
                               Style="{StaticResource FeldLabel}"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HkAnzahl" Grid.Column="0" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                        <TextBlock Grid.Column="1" Text="Stk ×" Style="{StaticResource Einheit}" Margin="6,0,8,0"/>
                        <TextBox x:Name="HkInhalt" Grid.Column="2" Text="5" Style="{StaticResource Eingabe}"
                                 TextChanged="Eingabe_Changed"/>
                        <TextBlock Grid.Column="3" Text="l" Style="{StaticResource Einheit}"/>
                    </Grid>

                    <!-- Wärmeerzeuger + Puffer -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Wärmeerzeuger" Style="{StaticResource FeldLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="l" Style="{StaticResource Einheit}"/>
                                <TextBox x:Name="ErzeugerInhalt" Style="{StaticResource Eingabe}"
                                         TextChanged="Eingabe_Changed"/>
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pufferspeicher" Style="{StaticResource FeldLabel}"/>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="l" Style="{StaticResource Einheit}"/>
                                <TextBox x:Name="PufferInhalt" Style="{StaticResource Eingabe}"
                                         TextChanged="Eingabe_Changed"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppAkzentLeiseBrush}"
                    CornerRadius="10" Padding="18" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Anlagenwasserinhalt" Style="{StaticResource FeldLabel}"/>
                    <TextBlock x:Name="ErgebnisLiter" Text="—" FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"/>
                    <TextBlock x:Name="ErgebnisAufschluesselungText" Text="" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource AppTextLeiseBrush}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button x:Name="EinfuegenButton" Content="➕ In Notiz einfügen"
                        Padding="12,7" Margin="0,0,10,0" Click="Einfuegen_Click"/>
                <Button x:Name="KopierenButton" Content="📋 Kopieren"
                        Padding="12,7" Click="Kopieren_Click"/>
            </StackPanel>
            <TextBlock x:Name="HinweisText" Text="" FontSize="12" Margin="0,10,0,0"
                       Foreground="{DynamicResource AppTextLeiseBrush}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
