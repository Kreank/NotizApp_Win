<Window x:Class="NotizApp.KiVorschlagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KI-Vorschlag" Width="560" Height="480"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Closing="Fenster_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitelText" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="Es wurde nur der Notiztext ohne Kundendaten übertragen."
                       FontSize="11" Opacity="0.6" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Laufender Zustand -->
        <StackPanel x:Name="WartePanel" Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Width="220" Height="6"/>
            <TextBlock Text="Claude denkt nach…" Margin="0,10,0,0"
                       HorizontalAlignment="Center" Opacity="0.7"/>
        </StackPanel>

        <!-- Ergebnis (editierbar vor dem Übernehmen) -->
        <TextBox x:Name="ErgebnisBox" Grid.Row="1" Visibility="Collapsed"
                 Margin="0,12,0,0" Padding="8"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="13"/>

        <!-- Fehler -->
        <TextBox x:Name="FehlerText" Grid.Row="1" Visibility="Collapsed"
                 Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#E5484D"
                 IsReadOnly="True" BorderThickness="0" Background="Transparent"
                 VerticalScrollBarVisibility="Auto"/>

        <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="False">
            <TextBlock x:Name="HinweisText" DockPanel.Dock="Left" FontSize="11"
                       Opacity="0.6" VerticalAlignment="Center" TextWrapping="Wrap"
                       MaxWidth="260"/>
            <Button x:Name="UebernehmenButton" DockPanel.Dock="Right" Content="Übernehmen"
                    MinWidth="110" Padding="0,6" FontWeight="SemiBold"
                    Visibility="Collapsed" Click="Uebernehmen_Click"/>
            <Button x:Name="AbbrechenButton" DockPanel.Dock="Right" Content="Abbrechen"
                    MinWidth="90" Padding="0,6" Margin="0,0,8,0"
                    Click="Abbrechen_Click"/>
        </DockPanel>
    </Grid>
</Window>
