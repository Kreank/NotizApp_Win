<Window x:Class="NotizApp.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eingabe" SizeToContent="Height" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="FrageText" Margin="0,0,0,8"/>
        <TextBox x:Name="EingabeBox" Padding="4"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Abbrechen" MinWidth="90" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" MinWidth="90" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
