<Window x:Class="NotizApp.QuickNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schnellnotiz" Width="480" SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterScreen" Topmost="True"
        ResizeMode="NoResize" ShowInTaskbar="False"
        KeyDown="Fenster_KeyDown">
    <StackPanel Margin="16">
        <!-- Vorlagen-Umschalter -->
        <StackPanel Orientation="Horizontal">
            <StackPanel.Resources>
                <Style TargetType="ToggleButton">
                    <Setter Property="Margin" Value="0,0,6,0"/>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </StackPanel.Resources>
            <ToggleButton x:Name="AnrufToggle" Content="📞 Anruf" IsChecked="True"
                          Checked="Vorlage_Checked"/>
            <ToggleButton x:Name="MeetingToggle" Content="👥 Meeting" Checked="Vorlage_Checked"/>
            <ToggleButton x:Name="AufgabeToggle" Content="☑ Aufgabe" Checked="Vorlage_Checked"/>
            <ToggleButton x:Name="LeerToggle" Content="📄 Leer" Checked="Vorlage_Checked"/>
        </StackPanel>

        <!-- Kundenfelder (nur Anruf) -->
        <Grid x:Name="KundenFelder" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="0,3,8,3"/>
                </Style>
            </Grid.Resources>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Kunde"/>
            <TextBox x:Name="KundeBox" Grid.Row="0" Grid.Column="1" Margin="0,3,12,3" Padding="3"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Telefon"/>
            <TextBox x:Name="TelefonBox" Grid.Row="0" Grid.Column="3" Margin="0,3" Padding="3"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Dringlichkeit"/>
            <ComboBox x:Name="DringlichkeitBox" Grid.Row="1" Grid.Column="1"
                      Margin="0,3,12,3" SelectedIndex="0">
                <ComboBoxItem Content="—" Tag=""/>
                <ComboBoxItem Content="🔴 Notfall" Tag="notfall"/>
                <ComboBoxItem Content="Termin" Tag="termin"/>
                <ComboBoxItem Content="Terminierung" Tag="terminierung"/>
                <ComboBoxItem Content="Info" Tag="info"/>
            </ComboBox>
        </Grid>

        <!-- Titel + Text -->
        <Grid Margin="0,12,0,0">
            <TextBox x:Name="TitelBox" Padding="4" FontSize="15"
                     FontWeight="SemiBold" ToolTip="Titel (leer = automatisch)"/>
            <TextBlock Text="Titel (leer = automatisch)" FontSize="15" Margin="7,0,0,0"
                       Foreground="{DynamicResource AppTextLeiseBrush}" Opacity="0.55"
                       IsHitTestVisible="False" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=TitelBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <TextBox x:Name="TextBox" Margin="0,8,0,0" Padding="4" MinHeight="110"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" MaxHeight="240"/>

        <!-- Stift -->
        <Expander Header="✍ Stift" Margin="0,8,0,0">
            <Border BorderThickness="1" CornerRadius="4" Margin="0,6,0,0"
                    BorderBrush="{DynamicResource AppRandBrush}">
                <InkCanvas x:Name="TintenFlaeche" Height="200" Background="Transparent"/>
            </Border>
        </Expander>

        <!-- Fußzeile -->
        <DockPanel Margin="0,14,0,0">
            <Button DockPanel.Dock="Right" Content="Speichern" MinWidth="110"
                    Padding="0,6" FontWeight="SemiBold" IsDefault="False"
                    ToolTip="Strg+Enter" Click="Speichern_Click"/>
            <Button DockPanel.Dock="Right" Content="Abbrechen" MinWidth="90"
                    Margin="0,0,8,0" Padding="0,6" Click="Abbrechen_Click"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Notizbuch:" VerticalAlignment="Center" Opacity="0.7"/>
                <ComboBox x:Name="NotizbuchBox" MinWidth="140" Margin="8,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
