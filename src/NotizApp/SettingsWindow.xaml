<Window x:Class="NotizApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" SizeToContent="Height" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="Datenordner" FontWeight="SemiBold"/>
        <DockPanel Margin="0,6,0,0">
            <Button DockPanel.Dock="Right" Content="Ändern…" Padding="10,4"
                    Margin="8,0,0,0" Click="OrdnerAendern_Click"/>
            <TextBox x:Name="OrdnerBox" Padding="4" IsReadOnly="True"
                     VerticalContentAlignment="Center"/>
        </DockPanel>
        <TextBlock Text="Änderung wirkt nach einem Neustart der App. Bestehende Dateien werden nicht verschoben."
                   FontSize="11" Opacity="0.6" Margin="0,4,0,0" TextWrapping="Wrap"/>

        <Separator Margin="0,16"/>

        <CheckBox x:Name="AutostartBox" Content="Mit Windows starten (im Hintergrund, als Tray-Symbol)"/>
        <CheckBox x:Name="HotkeyBox" Content="Globaler Hotkey Strg+Alt+N für die Schnellnotiz" Margin="0,10,0,0"/>

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Notizbuch für Schnellnotizen:" VerticalAlignment="Center"/>
            <ComboBox x:Name="QuickNotebookBox" MinWidth="180" Margin="10,0,0,0"/>
        </StackPanel>

        <Separator Margin="0,16"/>

        <TextBlock Text="Eigene Notiz-Vorlagen" FontWeight="SemiBold"/>
        <TextBlock Text="Erscheinen im Editor unter „📋 Vorlage“ und im Menü „Neue Notiz“ — z.B. Checklisten für Begehungen oder Notfall-Anrufe."
                   FontSize="11" Opacity="0.6" Margin="0,4,0,0" TextWrapping="Wrap"/>
        <DockPanel Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Margin="8,0,0,0" MinWidth="100">
                <Button Content="Neu…" Padding="0,4" Click="VorlageNeu_Click"/>
                <Button Content="Bearbeiten…" Padding="0,4" Margin="0,6,0,0" Click="VorlageBearbeiten_Click"/>
                <Button Content="Löschen" Padding="0,4" Margin="0,6,0,0" Click="VorlageLoeschen_Click"/>
            </StackPanel>
            <ListBox x:Name="VorlagenListe" Height="130"
                     MouseDoubleClick="VorlageBearbeiten_Click"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Abbrechen" MinWidth="90" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Speichern" MinWidth="90" IsDefault="True" Click="Speichern_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
