<Window x:Class="NotizApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NotizApp"
        xmlns:controls="clr-namespace:NotizApp.Controls"
        Title="NotizApp" Height="760" Width="1240"
        MinHeight="480" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NeueNotizCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SpeichernCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding SuchenCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="F5" Command="{Binding NeuLadenCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="F11" Command="{Binding FokusCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control" Key="B" Command="{Binding SidebarToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control+Shift" Key="B" Command="{Binding ListeToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Spalten-Trenner: dezente Linie, beim Drüberfahren deutlich (vorher
             unsichtbar — die Griffstelle war praktisch nicht zu finden) -->
        <Style x:Key="SpaltenSplitter" TargetType="GridSplitter">
            <Setter Property="Width" Value="7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Rectangle x:Name="Linie" Width="1" Margin="0,10"
                                       HorizontalAlignment="Center" RadiusX="1" RadiusY="1"
                                       Fill="{DynamicResource AppRandBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Linie" Property="Width" Value="3"/>
                                <Setter TargetName="Linie" Property="Fill"
                                        Value="{DynamicResource AppAkzentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Linie" Property="Width" Value="3"/>
                                <Setter TargetName="Linie" Property="Fill"
                                        Value="{DynamicResource AppAkzentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarSpalte" Width="230" MinWidth="170"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="ListeSpalte" Width="330" MinWidth="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="280"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="ChatSpalte" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- Firmen-Artwork als Hauch hinter allem; die Licht-Schimmer treiben darüber.
             Deckkraft je Design aus dem Farbschema (dunkel etwas präsenter als hell). -->
        <Image Grid.ColumnSpan="7" IsHitTestVisible="False"
               Source="pack://application:,,,/Assets/hintergrund-mitra.png"
               Stretch="UniformToFill"
               Opacity="{DynamicResource AppFondBildOpazitaet}"/>

        <!-- „Kupfer & Wasser": zwei sehr langsam treibende Licht-Schimmer hinter
             allen Inhalten (Animation startet im Code-Behind, respektiert die
             Windows-Animationseinstellung) -->
        <Canvas x:Name="GlowEbene" Grid.ColumnSpan="7" IsHitTestVisible="False"
                ClipToBounds="True">
            <Ellipse x:Name="GlowWasser" Width="820" Height="820"
                     Canvas.Left="-280" Canvas.Top="-320"
                     Fill="{DynamicResource AppGlowWasserBrush}"/>
            <Ellipse x:Name="GlowKupfer" Width="680" Height="680"
                     Canvas.Right="-240" Canvas.Bottom="-280"
                     Fill="{DynamicResource AppGlowKupferBrush}"/>
        </Canvas>

        <!-- ===== Sidebar ===== -->
        <DockPanel x:Name="SidebarPanel" Grid.Column="0" Margin="10,10,4,10">
            <DockPanel DockPanel.Dock="Top">
                <Button DockPanel.Dock="Right" Content="⮜" Margin="4,0,0,0" Padding="4,8"
                        BorderThickness="0" Background="Transparent"
                        Foreground="{DynamicResource AppTextBrush}"
                        ToolTip="Seitenleiste einklappen (Strg+B)"
                        Click="SidebarZuklappen_Click"/>
                <Button x:Name="NeueNotizButton"
                        Content="＋ Neue Notiz" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Padding="0,8"
                        Click="NeueNotiz_Click"
                        ContextMenuService.Placement="Bottom"/>
            </DockPanel>

            <Button DockPanel.Dock="Bottom" Content="⚙ Einstellungen"
                    HorizontalAlignment="Stretch" Padding="0,6" Margin="0,8,0,0"
                    Click="Einstellungen_Click"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0">
                <TextBlock Text="ANSICHTEN" FontSize="11" Opacity="0.6" Margin="4,0,0,4"/>
                <ListBox x:Name="AnsichtListe" BorderThickness="0" Background="Transparent"
                         SelectionChanged="AnsichtListe_SelectionChanged">
                    <ListBoxItem Content="▦ Dashboard" IsSelected="True"/>
                    <ListBoxItem Content="📚 Alle Notizen"/>
                    <ListBoxItem Content="☑ Aufgaben"/>
                </ListBox>
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0">
                <TextBlock Text="WERKZEUGE" FontSize="11" Opacity="0.6" Margin="4,0,0,4"/>
                <ListBox x:Name="WerkzeugListe" BorderThickness="0" Background="Transparent"
                         SelectionChanged="WerkzeugListe_SelectionChanged">
                    <ListBoxItem Content="🔥 Heizlast (überschlägig)"/>
                    <ListBoxItem Content="💧 Volumenstrom"/>
                    <ListBoxItem Content="🪣 Wasserinhalt"/>
                    <ListBoxItem Content="🫙 Ausdehnungsgefäß"/>
                    <ListBoxItem Content="🔁 Einheiten-Umrechner"/>
                </ListBox>
            </StackPanel>

            <DockPanel DockPanel.Dock="Top" Margin="4,14,0,4">
                <Button DockPanel.Dock="Right" Content="＋" Padding="6,0"
                        BorderThickness="0" Background="Transparent"
                        Foreground="{DynamicResource AppTextBrush}"
                        ToolTip="Neues Notizbuch" Click="NeuesNotizbuch_Click"/>
                <TextBlock Text="NOTIZBÜCHER" FontSize="11" Opacity="0.6"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <ListBox x:Name="NotizbuchListe" DockPanel.Dock="Top"
                     BorderThickness="0" Background="Transparent" MaxHeight="240"
                     SelectionChanged="NotizbuchListe_SelectionChanged"/>

            <TextBlock DockPanel.Dock="Top" Text="TAGS" FontSize="11" Opacity="0.6"
                       Margin="4,14,0,4"/>
            <ListBox x:Name="TagListe" BorderThickness="0" Background="Transparent"
                     SelectionChanged="TagListe_SelectionChanged"/>
        </DockPanel>

        <!-- Schmale Leiste, wenn die Sidebar eingeklappt ist -->
        <Button x:Name="SidebarRail" Grid.Column="0" Visibility="Collapsed"
                Margin="6,10,2,10" Padding="2,8" VerticalAlignment="Stretch"
                VerticalContentAlignment="Top" BorderThickness="0" Background="Transparent"
                Foreground="{DynamicResource AppTextBrush}"
                ToolTip="Seitenleiste ausklappen (Strg+B)" Click="SidebarAusklappen_Click">
            <StackPanel>
                <TextBlock Text="⮞" HorizontalAlignment="Center"/>
                <TextBlock Text="NOTIZBÜCHER" FontSize="10" Opacity="0.55"
                           Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </StackPanel>
        </Button>

        <GridSplitter x:Name="SplitterLinks" Grid.Column="1"
                      Style="{StaticResource SpaltenSplitter}"/>

        <!-- ===== Mittlere Spalte: Suche + Notizliste / Aufgabenliste ===== -->
        <DockPanel x:Name="ListePanel" Grid.Column="2" Margin="4,10,4,10">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button DockPanel.Dock="Right" Content="⮜" Margin="4,0,0,0" Padding="4,5"
                        BorderThickness="0" Background="Transparent"
                        Foreground="{DynamicResource AppTextBrush}"
                        ToolTip="Notizliste einklappen (Strg+Umschalt+B)"
                        Click="ListeZuklappen_Click"/>
                <TextBox x:Name="SuchBox" Padding="6,5" FontSize="13"
                         TextChanged="SuchBox_TextChanged"
                         ToolTip="Volltextsuche (Strg+F): Text, Handschrift, Titel, Tags, Kunde"/>
            </DockPanel>

            <TextBlock x:Name="ListeLeerHinweis" DockPanel.Dock="Bottom"
                       Text="" Opacity="0.55" Margin="4,6" TextWrapping="Wrap"/>

            <Grid>
                <ListBox x:Name="NotizListe" BorderThickness="0" Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="NotizListe_SelectionChanged"
                         KeyDown="NotizListe_KeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="2,6">
                                <Border DockPanel.Dock="Left" Width="3" CornerRadius="1.5"
                                        Margin="0,1,8,1"
                                        Background="{Binding NotizbuchFarbBrush}"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding AnzeigeTitel}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Vorschau}" Opacity="0.75" FontSize="12"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding AnzeigeUntertitel}" Opacity="0.55" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="VerschiebenMenu" Header="Verschieben nach"/>
                            <Separator/>
                            <MenuItem Header="Löschen" Click="NotizLoeschen_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <ListBox x:Name="AufgabenListe" BorderThickness="0" Background="Transparent"
                         Visibility="Collapsed" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="AufgabenListe_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="2,4">
                                <CheckBox DockPanel.Dock="Left" VerticalAlignment="Top"
                                          Margin="0,2,8,0"
                                          IsChecked="{Binding Erledigt, Mode=OneTime}"
                                          Click="Aufgabe_Umschalten"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding AnzeigeText}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Erledigt}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Ueberfaellig}" Value="True">
                                                        <Setter Property="Foreground" Value="#E5484D"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding AnzeigeQuelle}" Opacity="0.55"
                                               FontSize="11" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="Doppelklick öffnet die Quell-Notiz"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </DockPanel>

        <!-- Schmale Leiste, wenn die Notizliste eingeklappt ist -->
        <Button x:Name="ListeRail" Grid.Column="2" Visibility="Collapsed"
                Margin="2,10,2,10" Padding="2,8" VerticalAlignment="Stretch"
                VerticalContentAlignment="Top" BorderThickness="0" Background="Transparent"
                Foreground="{DynamicResource AppTextBrush}"
                ToolTip="Notizliste ausklappen (Strg+Umschalt+B)" Click="ListeAusklappen_Click">
            <StackPanel>
                <TextBlock Text="⮞" HorizontalAlignment="Center"/>
                <TextBlock Text="NOTIZEN" FontSize="10" Opacity="0.55"
                           Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </StackPanel>
        </Button>

        <GridSplitter x:Name="SplitterRechts" Grid.Column="3"
                      Style="{StaticResource SpaltenSplitter}"/>

        <!-- ===== Editor ===== -->
        <Grid Grid.Column="4">
            <controls:NoteEditor x:Name="Editor"/>
            <TextBlock x:Name="EditorLeerHinweis"
                       Text="Keine Notiz ausgewählt.&#10;&#10;＋ Neue Notiz (Strg+N) oder links eine Notiz wählen."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" Opacity="0.5"/>

            <!-- Dashboard-Ansicht (Sidebar „▦ Dashboard") — liegt über dem Editor -->
            <controls:DashboardView x:Name="Dashboard" Visibility="Collapsed"/>

            <!-- Werkzeuge (Sidebar „WERKZEUGE") — liegen ebenfalls über dem Editor.
                 Reihenfolge muss zur WerkzeugListe passen (ZeigeWerkzeug per Index). -->
            <controls:HeizlastRechner x:Name="HeizlastTool" Visibility="Collapsed"/>
            <controls:VolumenstromRechner x:Name="VolumenstromTool" Visibility="Collapsed"/>
            <controls:WasserinhaltRechner x:Name="WasserinhaltTool" Visibility="Collapsed"/>
            <controls:AusdehnungsgefaessRechner x:Name="AusdehnungTool" Visibility="Collapsed"/>
            <controls:EinheitenUmrechner x:Name="UmrechnerTool" Visibility="Collapsed"/>

            <!-- Schwebende Chat-Bubble: immer erreichbar, auch ohne offene Notiz -->
            <Button x:Name="ChatBubble" Width="46" Height="46"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,24,20" Cursor="Hand"
                    ToolTip="KI-Chat öffnen/schließen"
                    Click="ChatBubble_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Kreis"
                                     Fill="{DynamicResource AppAkzentBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.35"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="💬" FontSize="19"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Kreis" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <GridSplitter x:Name="SplitterChat" Grid.Column="5"
                      Style="{StaticResource SpaltenSplitter}" Visibility="Collapsed"/>

        <!-- ===== KI-Chat ===== -->
        <controls:KiChatPanel x:Name="ChatPanel" Grid.Column="6" Visibility="Collapsed"/>
    </Grid>
</Window>
