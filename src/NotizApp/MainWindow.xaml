<Window x:Class="NotizApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NotizApp"
        xmlns:controls="clr-namespace:NotizApp.Controls"
        Title="NotizApp" Height="760" Width="1240"
        MinHeight="480" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NeueNotizCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SpeichernCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding SuchenCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="F5" Command="{Binding NeuLadenCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" MinWidth="170"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="330" MinWidth="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <DockPanel Grid.Column="0" Margin="10,10,4,10">
            <Button x:Name="NeueNotizButton" DockPanel.Dock="Top"
                    Content="＋ Neue Notiz" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch" Padding="0,8"
                    Click="NeueNotiz_Click"
                    ContextMenuService.Placement="Bottom"/>

            <Button DockPanel.Dock="Bottom" Content="⚙ Einstellungen"
                    HorizontalAlignment="Stretch" Padding="0,6" Margin="0,8,0,0"
                    Click="Einstellungen_Click"/>

            <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0">
                <TextBlock Text="ANSICHTEN" FontSize="11" Opacity="0.6" Margin="4,0,0,4"/>
                <ListBox x:Name="AnsichtListe" BorderThickness="0" Background="Transparent"
                         SelectionChanged="AnsichtListe_SelectionChanged">
                    <ListBoxItem Content="📚 Alle Notizen" IsSelected="True"/>
                    <ListBoxItem Content="☑ Aufgaben"/>
                </ListBox>
            </StackPanel>

            <DockPanel DockPanel.Dock="Top" Margin="4,14,0,4">
                <Button DockPanel.Dock="Right" Content="＋" Padding="6,0"
                        BorderThickness="0" Background="Transparent"
                        ToolTip="Neues Notizbuch" Click="NeuesNotizbuch_Click"/>
                <TextBlock Text="NOTIZBÜCHER" FontSize="11" Opacity="0.6"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <ListBox x:Name="NotizbuchListe" DockPanel.Dock="Top"
                     BorderThickness="0" Background="Transparent" MaxHeight="240"
                     SelectionChanged="NotizbuchListe_SelectionChanged"/>

            <TextBlock DockPanel.Dock="Top" Text="TAGS" FontSize="11" Opacity="0.6"
                       Margin="4,14,0,4"/>
            <ListBox x:Name="TagListe" BorderThickness="0" Background="Transparent"
                     SelectionChanged="TagListe_SelectionChanged"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="Transparent"/>

        <!-- ===== Mittlere Spalte: Suche + Notizliste / Aufgabenliste ===== -->
        <DockPanel Grid.Column="2" Margin="4,10,4,10">
            <TextBox x:Name="SuchBox" DockPanel.Dock="Top" Margin="0,0,0,8"
                     Padding="6,5" FontSize="13"
                     TextChanged="SuchBox_TextChanged"
                     ToolTip="Volltextsuche (Strg+F): Text, Handschrift, Titel, Tags, Kunde"/>

            <TextBlock x:Name="ListeLeerHinweis" DockPanel.Dock="Bottom"
                       Text="" Opacity="0.55" Margin="4,6" TextWrapping="Wrap"/>

            <Grid>
                <ListBox x:Name="NotizListe" BorderThickness="0" Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="NotizListe_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,6">
                                <TextBlock Text="{Binding AnzeigeTitel}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Vorschau}" Opacity="0.75" FontSize="12"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding AnzeigeUntertitel}" Opacity="0.55" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="VerschiebenMenu" Header="Verschieben nach"/>
                            <Separator/>
                            <MenuItem Header="Löschen" Click="NotizLoeschen_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <ListBox x:Name="AufgabenListe" BorderThickness="0" Background="Transparent"
                         Visibility="Collapsed" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="AufgabenListe_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="2,4">
                                <CheckBox DockPanel.Dock="Left" VerticalAlignment="Top"
                                          Margin="0,2,8,0"
                                          IsChecked="{Binding Erledigt, Mode=OneTime}"
                                          Click="Aufgabe_Umschalten"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding AnzeigeText}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Erledigt}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Ueberfaellig}" Value="True">
                                                        <Setter Property="Foreground" Value="#E5484D"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding AnzeigeQuelle}" Opacity="0.55"
                                               FontSize="11" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="Doppelklick öffnet die Quell-Notiz"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </DockPanel>

        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="Transparent"/>

        <!-- ===== Editor ===== -->
        <Grid Grid.Column="4">
            <controls:NoteEditor x:Name="Editor"/>
            <TextBlock x:Name="EditorLeerHinweis"
                       Text="Keine Notiz ausgewählt.&#10;&#10;＋ Neue Notiz (Strg+N) oder links eine Notiz wählen."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" Opacity="0.5"/>
        </Grid>
    </Grid>
</Window>
